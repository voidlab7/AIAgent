# API Keys
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
SERPER_API_KEY=xxx  # Google Search API: https://serper.dev/
UNSPLASH_ACCESS_KEY=xxx  # Unsplash API
PEXELS_API_KEY=xxx

# 微信公众号
WECHAT_APP_ID=xxx
WECHAT_APP_SECRET=xxx

# 小红书 Cookie 路径
XIAOHONGSHU_COOKIE_PATH=~/.mcp/rednote/cookies.json

# 账号定位（可选，在 common/config.py 中配置更详细）
ACCOUNT_NAME=AI科技观察
ACCOUNT_VERTICAL=AI,科技,产品

# ============================================
# 服务器部署配置（用于 pawmbti 等项目的 SCP 部署）
# ============================================
# 服务器 root 密码（sshpass 使用）
SERVER_PASSWORD=your_server_password_here

# SSH Key 指纹（首次连接验证用，可选）
SSH_KEY_FINGERPRINT=SHA256:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
